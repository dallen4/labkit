{
  "name": "labkit",
  "version": "1.0.0",
  "description": "Reusable kit of agentic patterns for AI coding assistants",
  "type": "module",
  "bin": {
    "labkit": "./dist/index.mjs"
  },
  "files": [
    "dist",
    ".claude",
    ".cursor",
    ".windsurf",
    ".github",
    "scripts"
  ],
  "scripts": {
    "build": "tsdown",
    "build:binary": "nexe dist/index.mjs -o labkit --build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dallen4/labkit.git"
  },
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "agentic",
    "toolkit"
  ],
  "author": "Nieky Allen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dallen4/labkit/issues"
  },
  "homepage": "https://github.com/dallen4/labkit#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "cosmiconfig": "^9.0.1",
    "cpx2": "^8.0.0",
    "js-yaml": "^4.1.1",
    "tiged": "^2.12.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "nexe": "^5.0.0-beta.4",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
